{
  "name": "lanclip",
  "version": "0.1.0",
  "description": "LAN clipboard sync - copy on one device, paste on another",
  "main": "./dist/main.js",
  "type": "module",
  "bin": {
    "lanclip": "./dist/bin/lanclip.js"
  },
  "files": [
    "dist/"
  ],
  "keywords": ["clipboard", "sync", "lan", "network", "productivity", "copy-paste"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/main.ts",
    "dev:watch": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "debug-mdns": "tsx src/debug-mdns.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@lanclip/shared": "workspace:*",
    "bonjour-service": "^1.2.1",
    "clipboardy": "^4.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
