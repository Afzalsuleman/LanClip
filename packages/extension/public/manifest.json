{
  "manifest_version": 3,
  "name": "LANClip",
  "version": "0.1.0",
  "description": "Sync your clipboard across devices on the same network",
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "ws://localhost:8765/*",
    "ws://127.0.0.1:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LANClip"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
